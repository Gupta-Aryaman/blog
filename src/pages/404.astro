---
import Base from "../layouts/Base.astro";
---

<Base title="Not found">
  <div class="slab">
    <span class="slash">/</span> Error <span class="count">[ 404 ]</span>
  </div>
  <div class="page-body">
    <h1>404 — Page not found</h1>
    <div class="prose">
      <p>This page doesn't exist — it may have moved or never been written.</p>
      <p><a href="/">← Return to index</a></p>
    </div>
  </div>
</Base>
