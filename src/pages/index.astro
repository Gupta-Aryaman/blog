---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const all = await getCollection("blog");
const posts = all
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const published = all.filter(({ data }) => !data.draft).length;
const drafts = all.length - published;

const [featured, ...rest] = posts;

const words = featured.body ? featured.body.split(/\s+/).length : 0;
const minutes = Math.max(1, Math.round(words / 220));

const excerpt =
  featured.data.description ??
  (featured.body ?? "")
    .split(/\r?\n\r?\n/)
    .map((p) => p.trim())
    .find((p) => p && !p.startsWith("#") && !p.startsWith("![") && !p.startsWith("<") && !p.startsWith(">") && !p.startsWith("```"))
    ?.replace(/[*_`>[\]]/g, "")
    .replace(/\(([^)]*)\)/g, "")
    .slice(0, 220)
    .concat("…") ??
  "";

const fmtDate = (d: Date) => {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, "0");
  const day = String(d.getUTCDate()).padStart(2, "0");
  return `${y}.${m}.${day}`;
};

// short subtitle for index rows: description trimmed to one line
const sub = (desc?: string) => {
  if (!desc) return null;
  return desc.length > 72 ? desc.slice(0, 72).replace(/\s+\S*$/, "") + "…" : desc;
};

// first tag that isn't the post's own slug or a house tag
const topic = (tags: string[], id = "") =>
  (
    tags.find((t) => t !== "aryaman-batcave" && !id.includes(t) && !t.includes(id)) ??
    tags[0] ??
    "notes"
  ).replace(/-/g, " ");

const total = String(posts.length).padStart(2, "0");

const shelf = [
  { ref: "AI/ML", t: "Attention Is All You Need", a: "Vaswani et al. · 2017" },
  { ref: "AI/ML", t: "MemGPT: Towards LLMs as Operating Systems", a: "Packer et al. · 2023" },
  { ref: "Quantum", t: "Quantum Supremacy Using a Programmable Superconducting Processor", a: "Arute et al. · 2019" },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "aryaman.space",
      url: "https://aryaman.space",
      description:
        "Aryaman Gupta's engineering blog — deep dives into Python internals, distributed systems, NLP, and the papers worth reading twice.",
      author: { "@id": "https://aryaman.space/#person" },
    },
    {
      "@type": "Person",
      "@id": "https://aryaman.space/#person",
      name: "Aryaman Gupta",
      url: "https://aryaman.space",
      jobTitle: "Software Engineer",
      sameAs: [
        "https://github.com/gupta-aryaman",
        "https://x.com/aryamantwts",
        "https://www.linkedin.com/in/aryamangupta1/",
      ],
    },
  ],
};

const tickerItems = [
  ["Posts shipped", String(published).padStart(2, "0")],
  ["Drafts brewing", String(drafts).padStart(2, "0")],
  ["Papers read", "10+"],
  ["Writing since", "2023"],
  ["GIL status", "still locked"],
];
---

<Base schema={schema}>
  <section class="hero">
    <div class="eyebrow">Personal engineering notes · Est. 2023</div>
    <h1>Aryaman<br />Dot Space<span class="cursor"></span></h1>
    <div class="hero-foot">
      <p>
        I take systems apart and write down what I find — <code>python</code> internals,
        distributed systems, NLP pipelines, and the papers worth reading twice.
      </p>
      <a href="/blog/" class="hero-cta">Browse all posts →</a>
    </div>
  </section>

  <div class="slab"><span class="slash">/</span> Featured post <span class="count">[ 01 / {total} ]</span></div>
  <section class="feature">
    <div class="feature-fig">
      <canvas id="fig2" width="340" height="240" aria-hidden="true"></canvas>
      <div class="fig-tag"><span>[ Fig. 1 ] — Random walk</span><span>{topic(featured.data.tags, featured.id)}</span></div>
    </div>
    <div class="feature-body">
      <h2><a href={`/blog/${featured.id}/`}>{featured.data.title}</a></h2>
      <p class="sum">SUMMARY: {excerpt}</p>
      <div class="chips">
        <span class="chip fill">{topic(featured.data.tags, featured.id)}</span>
        {featured.data.tags.slice(1, 3).map((t) => (
          <span class="chip">{t}</span>
        ))}
        <span class="chip">{fmtDate(featured.data.date)}</span>
      </div>
      <a class="go" href={`/blog/${featured.id}/`}>Read → {minutes} min</a>
    </div>
  </section>

  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[0, 1].map(() =>
        tickerItems.map(([k, v]) => (
          <>
            <span>{k}: <b>{v}</b></span>
            <span>/</span>
          </>
        )),
      )}
    </div>
  </div>

  <div class="slab">
    <span class="slash">/</span> Index — recent
    <a class="count" href="/blog/">[ View all — {total} → ]</a>
  </div>
  <div class="index-head">
    <div>/ Date</div>
    <div>/ Name</div>
    <div class="h-topic">/ Topic</div>
    <div></div>
  </div>
  {
    rest.slice(0, 4).map((post) => (
      <a class="row" href={`/blog/${post.id}/`}>
        <div class="date">{fmtDate(post.data.date)}</div>
        <div class="name">
          {post.data.title}
          {sub(post.data.description) && <small>{sub(post.data.description)}</small>}
        </div>
        <div class="topic">{topic(post.data.tags, post.id)}</div>
        <div class="goto">Read →</div>
      </a>
    ))
  }

  <div class="slab"><span class="slash">/</span> Papershelf <span class="count">[ Recently read ]</span></div>
  <div class="shelf">
    {shelf.map((p, i) => (
      <a class="paper-card" href="/papershelf/">
        <span class="ref">[ Ref. {String(i + 1).padStart(2, "0")} ] — {p.ref}</span>
        <span class="t">{p.t}</span>
        <span class="a">{p.a}</span>
      </a>
    ))}
  </div>

  <script>
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const ink = () => getComputedStyle(document.documentElement).getPropertyValue("--ink").trim();
    const panel = () => getComputedStyle(document.documentElement).getPropertyValue("--panel").trim();

    // Fig. 1 — pixel random walker
    const c2 = document.getElementById("fig2") as HTMLCanvasElement | null;
    if (c2) {
      const x2 = c2.getContext("2d")!;
      let wx = c2.width / 2, wy = c2.height / 2;
      let frame = 0;
      const step = () => {
        // occasionally let the trace fade by repainting the panel at low alpha
        if (frame++ % 2 === 0) {
          x2.globalAlpha = 0.06;
          x2.fillStyle = panel();
          x2.fillRect(0, 0, c2.width, c2.height);
          x2.globalAlpha = 1;
        }
        x2.fillStyle = ink();
        for (let k = 0; k < 6; k++) {
          wx += (Math.random() - 0.5) * 26;
          wy += (Math.random() - 0.5) * 26;
          wx = Math.max(8, Math.min(c2.width - 8, wx));
          wy = Math.max(8, Math.min(c2.height - 8, wy));
          x2.fillRect(Math.round(wx / 6) * 6, Math.round(wy / 6) * 6, 4, 4);
        }
        if (!reduced) requestAnimationFrame(step);
      };
      x2.fillStyle = panel();
      x2.fillRect(0, 0, c2.width, c2.height);
      step();
    }
  </script>
</Base>
