---
import "@fontsource-variable/archivo";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/700.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: string;
  tags?: string[];
  schema?: Record<string, unknown>;
}

const {
  title,
  description = "Aryaman Gupta's engineering blog — deep dives into Python internals, distributed systems, NLP, and the papers worth reading twice.",
  image,
  article = false,
  publishedTime,
  tags = [],
  schema,
} = Astro.props;

const siteTitle = title ? `${title} · aryaman.space` : "aryaman.space";
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image ?? "/images/share.png", Astro.site);

const nav = [
  { href: "/blog/", label: "Blogs", key: "B" },
  { href: "/papershelf/", label: "Papershelf", key: "P" },
  { href: "/about/", label: "About", key: "A" },
  { href: "/index.xml", label: "RSS", key: "R" },
];
const path = Astro.url.pathname;
const current = (href: string) => path === href || (href === "/blog/" && path.startsWith("/blog/"));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Aryaman Gupta" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/images/favicon.png" type="image/png" />
    <link rel="alternate" type="application/rss+xml" title="aryaman.space" href="/index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title ?? "aryaman.space"} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="aryaman.space" />
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title ?? "aryaman.space"} />
    {article && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {article && <meta property="article:author" content="Aryaman Gupta" />}
    {article && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@aryamantwts" />
    <meta name="twitter:creator" content="@aryamantwts" />
    <meta name="twitter:title" content={title ?? "aryaman.space"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <script is:inline>
      const stored = localStorage.getItem("theme");
      const dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.classList.toggle("dark", dark);
    </script>
  </head>
  <body>
    <div class="sheet">
      <header class="topbar">
        <a class="brand" href="/">ARYAMAN<span>.SPACE</span></a>
        <nav>
          {nav.map(({ href, label, key }) => (
            <a href={href} aria-current={current(href) ? "page" : undefined}>
              <span class="key" aria-hidden="true">{key}</span>{label}
            </a>
          ))}
          <button id="theme-toggle" aria-label="Toggle color theme (shortcut: I)">
            <span class="key" aria-hidden="true">I</span>
            <span class="toggle-light">Invert</span>
            <span class="toggle-dark">Revert</span>
          </button>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="foot">
        <span>© {new Date().getFullYear()} ARYAMAN GUPTA</span>
        <span>
          <a href="https://github.com/gupta-aryaman" target="_blank" rel="noopener">GitHub</a> ·
          <a href="https://x.com/aryamantwts" target="_blank" rel="noopener">Twitter</a> ·
          <a href="https://www.linkedin.com/in/aryamangupta1/" target="_blank" rel="noopener">LinkedIn</a> ·
          <a href="/index.xml">RSS</a>
        </span>
        <span>Built with Astro · Set in Archivo + Plex Mono</span>
      </footer>
    </div>

    <script>
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const dark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", dark ? "dark" : "light");
      });

      document.addEventListener("keydown", (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const target = e.target as HTMLElement;
        if (target.closest("input, textarea, select, [contenteditable]")) return;
        const routes: Record<string, string> = {
          h: "/",
          b: "/blog/",
          p: "/papershelf/",
          a: "/about/",
          r: "/index.xml",
        };
        const key = e.key.toLowerCase();
        if (key === "i") {
          (document.getElementById("theme-toggle") as HTMLButtonElement)?.click();
        } else if (routes[key]) {
          window.location.href = routes[key];
        }
      });
    </script>
  </body>
</html>
