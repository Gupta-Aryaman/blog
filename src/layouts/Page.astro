---
import Base from "./Base.astro";

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title} description={frontmatter.description}>
  <div class="slab">
    <span class="slash">/</span> {frontmatter.title}
  </div>
  <div class="page-body">
    <h1>{frontmatter.title}</h1>
    <div class="prose">
      <slot />
    </div>
  </div>
</Base>
